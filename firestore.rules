rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 投稿（誰でも読める / ログイン済みなら作成・更新・削除）
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;

      // 返信（投稿へのコメント）
      // 更新: 投稿者本人は編集・削除可 / ログイン済みならいいね用の likes, likedBy のみ更新可
      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null &&
          (resource.data.authorId == request.auth.uid ||
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']));
        allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
      }
    }

    // ユーザープロフィール（自分のドキュメントは全フィールド読み書き / 他ユーザーは followersCount, followers のみ更新可＝フォロー用）
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        (request.auth.uid == userId || request.resource.data.keys().hasOnly(['followersCount', 'followers']));
      allow update: if request.auth != null &&
        (request.auth.uid == userId ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'followers']));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
