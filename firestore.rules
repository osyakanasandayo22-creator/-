rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function safePostPayload() {
      return request.resource.data.title is string
        && request.resource.data.title.size() <= 50
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 40000
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 20
        && request.resource.data.likes is int
        && request.resource.data.likes >= 0
        && request.resource.data.authorId == request.auth.uid;
    }
    function safeReplyPayload() {
      return request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        && request.resource.data.authorId == request.auth.uid;
    }
    // スレッド本体（掲示板のトピック）新規作成
    function safeThreadCreatePayload() {
      return request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.authorId is string
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorDisplayName.size() <= 20
        && request.resource.data.authorIcon is string
        && request.resource.data.authorIcon.size() <= 8
        && request.resource.data.authorIconBg is string
        && request.resource.data.authorIconBg.size() <= 20
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.replyCount is int
        && request.resource.data.replyCount == 0;
    }
    // 返信が付いたあと: replyCount をちょうど +1、他フィールドは据え置き
    function threadReplyBump() {
      let prevC = resource.data.keys().hasAll(['replyCount']) ? int(resource.data.replyCount) : 0;
      return isSignedIn()
        && int(request.resource.data.replyCount) == prevC + 1
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.title == resource.data.title
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'replyCount'])
        && request.resource.data.replyCount is int
        && request.resource.data.replyCount > 0
        && request.resource.data.replyCount <= 1000;
    }
    function threadOwnerUpdate() {
      return isSignedIn()
        && request.auth.uid == resource.data.authorId
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        // レス数は返信専用ルール（threadReplyBump）でのみ増やせる
        && int(request.resource.data.keys().hasAll(['replyCount']) ? request.resource.data.replyCount : 0)
           == int(resource.data.keys().hasAll(['replyCount']) ? resource.data.replyCount : 0);
    }
    // スレッドへのレス（2ch 風）
    function safeThreadReplyPayload() {
      return request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        && request.resource.data.authorId is string
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorDisplayName.size() <= 20
        && request.resource.data.createdAt is string;
    }
    // 自分のスレッド返信の表示名のみ更新（本文・日時は変更不可）
    function threadReplyAuthorNameOnlyUpdate() {
      return isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.body == resource.data.body
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorDisplayName.size() > 0
        && request.resource.data.authorDisplayName.size() <= 20
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorDisplayName']);
    }

    // 投稿（誰でも読める / ログイン済みなら作成・更新・削除）
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && safePostPayload();
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && safePostPayload();
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      // 返信（投稿へのコメント）
      // 更新: 投稿者本人は編集・削除可 / ログイン済みならいいね用の likes, likedBy のみ更新可
      match /replies/{replyId} {
        allow read: if true;
        allow create: if isSignedIn() && safeReplyPayload();
        allow update: if isSignedIn() &&
          (resource.data.authorId == request.auth.uid ||
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']));
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // スレッド（誰でも読める / 作成者がスレッド文書を管理 / 返信者は replyCount+updatedAt のみ）
    match /threads/{threadId} {
      allow read: if true;
      allow create: if isSignedIn() && safeThreadCreatePayload();
      allow update: if isSignedIn() && (threadOwnerUpdate() || threadReplyBump());
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /replies/{replyId} {
        allow read: if true;
        allow create: if isSignedIn() && safeThreadReplyPayload();
        allow update: if isSignedIn() && threadReplyAuthorNameOnlyUpdate();
        allow delete: if false;
      }
    }

    // ユーザープロフィール（自分のドキュメントは全フィールド読み書き / 他ユーザーは followersCount と followers のみ更新可＝フォロー用）
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        (request.auth.uid == userId || request.resource.data.keys().hasOnly(['followersCount', 'followers']));
      allow update: if isSignedIn() &&
        (request.auth.uid == userId ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'followers']));
      allow delete: if isOwner(userId);
    }
  }
}
