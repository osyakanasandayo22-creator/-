rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function safePostPayload() {
      return request.resource.data.title is string
        && request.resource.data.title.size() <= 50
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 40000
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 20
        && request.resource.data.likes is int
        && request.resource.data.likes >= 0
        && request.resource.data.authorId == request.auth.uid;
    }
    function safeReplyPayload() {
      return request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        && request.resource.data.authorId == request.auth.uid;
    }

    // 投稿（誰でも読める / ログイン済みなら作成・更新・削除）
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && safePostPayload();
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && safePostPayload();
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      // 返信（投稿へのコメント）
      // 更新: 投稿者本人は編集・削除可 / ログイン済みならいいね用の likes, likedBy のみ更新可
      match /replies/{replyId} {
        allow read: if true;
        allow create: if isSignedIn() && safeReplyPayload();
        allow update: if isSignedIn() &&
          (resource.data.authorId == request.auth.uid ||
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']));
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // ユーザープロフィール（自分のドキュメントは全フィールド読み書き / 他ユーザーは followersCount と followers のみ更新可＝フォロー用）
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        (request.auth.uid == userId || request.resource.data.keys().hasOnly(['followersCount', 'followers']));
      allow update: if isSignedIn() &&
        (request.auth.uid == userId ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'followers']));
      allow delete: if isOwner(userId);
    }
  }
}
